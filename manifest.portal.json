{
  "name": "Goallord Portal",
  "short_name": "Goallord Portal",
  "description": "The Goallord Creativity portal - sign in as a student, lecturer, or admin to manage courses, messages, attendance, and more from your phone.",
  "id": "/portal.html",
  "start_url": "/portal.html?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "orientation": "portrait",
  "background_color": "#0d0f14",
  "theme_color": "#0d0f14",
  "lang": "en-NG",
  "dir": "ltr",
  "categories": ["education", "productivity", "business"],
  "prefer_related_applications": false,
  "icons": [
    { "src": "/assets/images/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/assets/images/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/assets/images/icons/icon-192-maskable.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "/assets/images/icons/icon-512-maskable.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "shortcuts": [
    {
      "name": "Messages",
      "short_name": "Messages",
      "description": "Open your conversations",
      "url": "/portal.html?go=messages",
      "icons": [{ "src": "/assets/images/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Student sign in",
      "short_name": "Student",
      "description": "Sign in to the student portal",
      "url": "/student-login.html",
      "icons": [{ "src": "/assets/images/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Lecturer sign in",
      "short_name": "Lecturer",
      "description": "Sign in to the lecturer portal",
      "url": "/lecturer-login.html",
      "icons": [{ "src": "/assets/images/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ]
}
